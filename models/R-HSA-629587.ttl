<http://model.geneontology.org/R-HSA-629587/R-HSA-629587>
        a       <http://purl.obolibrary.org/obo/GO_0007268> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "Nicotinic acetylcholne receptors that have low Ca2+ permeability allow the influx of Na+ which causes depolarization of the membrane initiating voltage dependent responses such as activation of voltage dependent opening of Ca2+ channels and thus eliciting an increase in Ca2+ and downstream signaling. These receptors could be found in both presynaptic and postsynaptic terminals." ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Highly sodium permeable postsynaptic acetylcholine nicotinic receptors" ;
        <http://purl.org/dc/elements/1.1/contributor>
                "Reviewed: Restituito, S, 2008-11-27 12:38:49" , "Edited: Gillespie, ME, 2010-05-18" , "Authored: Mahajan, SS, 2010-04-26" , "Reviewed: Wen, Hua, 2020-01-24" , "GOC:reactome_curators" ;
        <http://purl.org/dc/elements/1.1/date>
                "2026-07-02" ;
        <http://purl.org/pav/providedBy>
                "https://reactome.org" ;
        <http://www.geneontology.org/formats/oboInOwl#hasDbXref>
                "R-HSA-629587" ;
