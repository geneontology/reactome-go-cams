<http://model.geneontology.org/ev_w_id_R-HSA-9840795_RO_0002234_R-ALL-1605637_lysosomal_lumen_Reactome_R-HSA-9840310_R-HSA-9840795_enabled_by_UniProt_Q8IW92_R-HSA-9840795_controller>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
        <http://purl.org/dc/elements/1.1/contributor>
