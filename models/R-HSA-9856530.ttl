<http://model.geneontology.org/R-HSA-9855031_R-HSA-9855106>
        a       <http://identifiers.org/uniprot/Q9Y490> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "located_in cytosol" , "Original Reactome ID: UniProt_Q9Y490" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "TLN1" ;
        <http://purl.org/dc/elements/1.1/contributor>
                "GOC:reactome_curators" ;
        <http://purl.org/dc/elements/1.1/date>
                "2026-07-02" ;
        <http://purl.org/pav/providedBy>
                "https://reactome.org" ;
        <http://www.geneontology.org/formats/oboInOwl#hasDbXref>
                "Reactome:R-HSA-9855031" ;
        <http://www.w3.org/2004/02/skos/core#exactMatch>
                <http://www.reactome.org/biopax/97/48887#Protein33661> ;
