<http://model.geneontology.org/ev_w_id_R-HSA-140696_RO_0002233_R-HSA-140697_R-HSA-140696_Reactome_R-HSA-9769743>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
