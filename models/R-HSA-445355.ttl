<http://model.geneontology.org/ev_w_id_REACTO_R-HSA-392141_O75343_P33402_R-HSA-392152_controller_BFO_0000051_UniProtKB_O75343_REACTO_R-HSA-392141_O75343_P33402_R-HSA-392152_controller_component_Reactome_R-HSA-392152>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
