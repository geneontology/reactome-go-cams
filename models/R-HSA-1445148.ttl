<http://model.geneontology.org/ev_w_id_R-HSA-1445144_RO_0002333_UniProt_P31751_R-HSA-1445144_controller_Reactome_R-HSA-1445148_R-HSA-1445144_enabled_by_UniProt_P31751_R-HSA-1445144_controller>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
