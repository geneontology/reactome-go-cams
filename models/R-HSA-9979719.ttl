<http://identifiers.org/uniprot/P53634>
        a       <http://www.w3.org/2002/07/owl#Class> .

<http://model.geneontology.org/R-HSA-9979719/R-HSA-9979719>
        a       <http://purl.obolibrary.org/obo/GO_0019884> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "B cells are professional antigen presenting cells in the sense that they process antigens and display the resulting antigen peptides on MHC class II complexes (reviewed in McShane and Malinova 2022, Rastogi et al. 2022). Antigens bound to the B cell receptor (BCR) are internalized, unfolded, and digested by proteases. The resulting peptide fragments are then loaded onto MHC II complexes that are made accessible by the removal of the class II-associated invariant chain peptide (CLIP) from MHC II by HLA-DM. In B cells, trafficking of the BCR:antigen complex is accelerated compared with trafficking of pinocytosed antigens and the antigen processing reactions occur in distinctive multivesicular bodies (Cheng et al. 1999, Lankar et al. 2002)." ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Processing of antigen in germinal center B cells" ;
        <http://purl.org/dc/elements/1.1/contributor>
                "Reviewed: Yu, Chuanjiang, 2026-04-27" , "Authored: May, Bruce, 2026-01-20" , "GOC:reactome_curators" , "Edited: May, Bruce, 2026-01-20" ;
        <http://purl.org/dc/elements/1.1/date>
                "2026-07-02" ;
        <http://purl.org/pav/providedBy>
                "https://reactome.org" ;
        <http://www.geneontology.org/formats/oboInOwl#hasDbXref>
                "R-HSA-9979719" ;
        <http://www.w3.org/2004/02/skos/core#narrower>
                <http://model.geneontology.org/R-HSA-9938027/R-HSA-9938027> ;
        <http://www.w3.org/2004/02/skos/core#note>
                "org.biopax.paxtools.model.level3.Pathway" .

