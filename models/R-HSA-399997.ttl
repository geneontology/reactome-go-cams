[ a       <http://www.w3.org/2002/07/owl#Axiom> ;
  <http://www.w3.org/2000/01/rdf-schema#comment>
          "Imported from Reactome: https://reactome.org/content/detail/R-HSA-399997" , "Provides Input For Rule. The relation 'Gq alpha:G beta:G gamma dissociates to Gq alpha:GTP and G beta:G gamma' 'null' 'Gq alpha activates Phospholipase C beta' was inferred because:\n reaction1 has an output that is an input of reaction 2. " ;
  <http://geneontology.org/lego/evidence>
          <http://model.geneontology.org/ev_w_id_R-HSA-400027_enabled_by_UniProt_P29992_R-HSA-400027_controller_RO_0002413_R-HSA-400023_enabled_by_UniProt_P29992_R-HSA-400023_controller_Reactome_R-HSA-399997> ;
  <http://purl.org/dc/elements/1.1/contributor>
          "GOC:reactome_curators" ;
  <http://purl.org/dc/elements/1.1/date>
          "2026-07-02" ;
  <http://purl.org/pav/providedBy>
          "https://reactome.org" ;
  <http://www.w3.org/2002/07/owl#annotatedProperty>
          <http://purl.obolibrary.org/obo/RO_0002413> ;
  <http://www.w3.org/2002/07/owl#annotatedSource>
          <http://model.geneontology.org/R-HSA-400027_enabled_by_UniProt_P29992_R-HSA-400027_controller> ;
  <http://www.w3.org/2002/07/owl#annotatedTarget>
          <http://model.geneontology.org/R-HSA-400023_enabled_by_UniProt_P29992_R-HSA-400023_controller>
