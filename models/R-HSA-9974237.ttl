<http://purl.org/dc/elements/1.1/title>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty> .

<http://model.geneontology.org/R-HSA-9974237/R-HSA-9974237>
        a       <http://purl.obolibrary.org/obo/GO_0008150> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "DNA double strand break response can be negatively regulated by ubiquitinylation-dependent proteasome-mediated degradation of proteins that orchestrate it. For example, 26S proteasome-mediated degradation of BRCA1 and its heterodimerization partner, BARD1, is triggered by polyubiquitination of these two proteins by the Cullin4-RBX1-DDB1 (CRL4) E3 ubiquitin ligase complexes that have DCAF8L1 or DCAF8L2 as their substrate recognition subunits, with CRL4A-DCAF8L1 targeting both BRCA1 and BARD1 (Liu et al. 2022), and CRL4-DCAF8L2 targeting BARD1 only (Deng et al. 2022)." ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Negative Regulation of DNA Double Strand Break Response" ;
        <http://purl.org/dc/elements/1.1/contributor>
                "GOC:reactome_curators" , "Authored: Orlic-Milacic, Marija, 2025-11-21" ;
        <http://purl.org/dc/elements/1.1/date>
                "2026-07-02" ;
        <http://purl.org/pav/providedBy>
                "https://reactome.org" ;
        <http://www.geneontology.org/formats/oboInOwl#hasDbXref>
                "R-HSA-9974237" ;
        <http://www.w3.org/2004/02/skos/core#narrower>
                <http://model.geneontology.org/R-HSA-5693606/R-HSA-5693606> ;
        <http://www.w3.org/2004/02/skos/core#note>
                "org.biopax.paxtools.model.level3.Pathway" .

<http://purl.obolibrary.org/obo/RO_0002333>
