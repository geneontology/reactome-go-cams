          <http://model.geneontology.org/ev_w_id_R-HSA-1671691_RO_0002333_REACTO_R-HSA-1369095_O60674_P01236_P16471_P42229_R-HSA-1671691_controller_Reactome_R-HSA-1671691_R-HSA-1671691_enabled_by_REACTO_R-HSA-1369095_O60674_P01236_P16471_P42229_R-HSA-1671691_controller> , <http://model.geneontology.org/ev_w_id_R-HSA-1671691_RO_0002333_REACTO_R-HSA-1369095_O60674_P01236_P16471_P42229_R-HSA-1671691_controller_Reactome_R-HSA-1170546_R-HSA-1671691_enabled_by_REACTO_R-HSA-1369095_O60674_P01236_P16471_P42229_R-HSA-1671691_controller> ;
