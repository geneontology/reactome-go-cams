<http://model.geneontology.org/ev_w_id_R-HSA-6811414_enabled_by_UniProt_P84077_R-HSA-6811414_controller_BFO_0000066_reaction_R-HSA-6811414_enabled_by_UniProt_P84077_R-HSA-6811414_controller_location_lociGO_0005829_Reactome_R-HSA-6811434>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
