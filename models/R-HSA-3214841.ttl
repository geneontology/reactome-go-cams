<http://model.geneontology.org/R-HSA-5634750>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/GO_0140938> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "Original Reactome ID: R-HSA-5634750" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "EHMT1:EHMT2 methylates lysine-10 of histone H3" ;
        <http://purl.obolibrary.org/obo/BFO_0000050>
                <http://model.geneontology.org/R-HSA-3214841/R-HSA-3214841> ;
        <http://purl.obolibrary.org/obo/BFO_0000066>
