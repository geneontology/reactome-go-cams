<http://model.geneontology.org/ev_w_id_R-HSA-9684033_RO_0002234_R-ALL-9639443_cytosol_Reactome_R-HSA-9684033>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
