        a       <http://purl.obolibrary.org/obo/GO_0099104> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "Original Reactome ID: R-HSA-400063" , "split from set-enabled reaction R-HSA-400063" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Low conductance potassium channels in pancreatic beta cells open in response to epinephrine" ;
        <http://purl.obolibrary.org/obo/BFO_0000050>
                <http://model.geneontology.org/R-HSA-400042/R-HSA-400042> ;
        <http://purl.obolibrary.org/obo/BFO_0000066>
