<http://model.geneontology.org/ev_w_id_R-HSA-9948300_RO_0002233_R-ALL-113592_cytosol_Reactome_R-HSA-9948300>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
        <http://purl.org/dc/elements/1.1/contributor>
                "GOC:reactome_curators" ;
        <http://purl.org/dc/elements/1.1/date>
                "2026-07-02" ;
