<http://model.geneontology.org/R-HSA-8867288_enabled_by_UniProt_O60337_R-HSA-8867288_controller>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/GO_0061630> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "split from set-enabled reaction R-HSA-8867288" , "Original Reactome ID: R-HSA-8867288" ;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "OS9:SEL1:ERAD E3 ligase:DERL2 ubiquitinates unfolded protein:(GlcNAc)2 (Man)9-5" ;
        <http://purl.obolibrary.org/obo/BFO_0000050>
                <http://model.geneontology.org/R-HSA-901032/R-HSA-901032> ;
        <http://purl.obolibrary.org/obo/BFO_0000066>
                <http://model.geneontology.org/reaction_R-HSA-8867288_enabled_by_UniProt_O60337_R-HSA-8867288_controller_location_lociGO_0005789> ;
        <http://purl.obolibrary.org/obo/RO_0002333>
