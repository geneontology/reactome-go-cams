                "https://reactome.org" ;
        <http://www.geneontology.org/formats/oboInOwl#hasDbXref>
                "Reactome:R-HSA-8867288" ;
        <http://www.w3.org/2004/02/skos/core#exactMatch>
                <http://www.reactome.org/biopax/97/48887#BiochemicalReaction9464> ;
