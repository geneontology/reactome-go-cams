<http://model.geneontology.org/reaction_R-HSA-9947306_enabled_by_R-HSA-9943337_R-HSA-9947306_controller_location_lociGO_0005654>
        a       <http://purl.obolibrary.org/obo/GO_0005654> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
