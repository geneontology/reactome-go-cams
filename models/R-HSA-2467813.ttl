<http://model.geneontology.org/ev_w_id_R-HSA-2545203_BFO_0000050_R-HSA-2467813/R-HSA-2467813_Reactome_R-HSA-2467813>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
