<http://model.geneontology.org/R-HSA-9938027>
        a       <http://www.w3.org/2002/07/owl#Ontology> ;
        <http://www.w3.org/2000/01/rdf-schema#comment>
                "http://www.reactome.org" , "For logical inference, import the integrated tbox ontology http://purl.obolibrary.org/obo/go/extensions/go-lego-reacto.owl" , "Imported from Reactome: https://reactome.org/content/detail/R-HSA-9938027" ;
