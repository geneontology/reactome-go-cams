[ a       <http://www.w3.org/2002/07/owl#Axiom> ;
  <http://www.w3.org/2000/01/rdf-schema#comment>
          "Imported from Reactome: https://reactome.org/content/detail/R-HSA-187577" ;
  <http://geneontology.org/lego/evidence>
          <http://model.geneontology.org/ev_w_id_R-HSA-177750_R-HSA-187574_controller_BFO_0000051_UniProtKB_P28070_R-HSA-177750_R-HSA-187574_component_Reactome_R-HSA-177750> , <http://model.geneontology.org/ev_w_id_R-HSA-177750_R-HSA-187574_controller_BFO_0000051_UniProtKB_P28070_R-HSA-177750_R-HSA-187574_component_Reactome_R-HSA-187577> ;
  <http://purl.org/dc/elements/1.1/contributor>
          "GOC:reactome_curators" ;
  <http://purl.org/dc/elements/1.1/date>
          "2026-07-02" ;
