<http://model.geneontology.org/ev_w_id_R-HSA-1296043_enabled_by_UniProt_Q9P1Z3_R-HSA-1296043_controller_BFO_0000066_reaction_R-HSA-1296043_enabled_by_UniProt_Q9P1Z3_R-HSA-1296043_controller_location_lociGO_0005886_Reactome_R-HSA-1296061>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
