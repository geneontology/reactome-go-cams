  <http://geneontology.org/lego/evidence>
          <http://model.geneontology.org/ev_w_id_R-HSA-5685994_RO_0002233_R-ALL-113518_R-HSA-5685994_Reactome_R-HSA-5693607_R-HSA-5685994_enabled_by_REACTO_R-HSA-5685989_combo87df206a_R-HSA-5685994_controller> , <http://model.geneontology.org/ev_w_id_R-HSA-5685994_RO_0002233_R-ALL-113518_R-HSA-5685994_Reactome_R-HSA-5685994_R-HSA-5685994_enabled_by_REACTO_R-HSA-5685989_combo87df206a_R-HSA-5685994_controller> ;
