<http://model.geneontology.org/ev_w_id_R-HSA-1226094_RO_0002233_R-ALL-29358_nucleoplasm_Reactome_R-HSA-1226094_R-HSA-1226094_enabled_by_R-HSA-8949895_R-HSA-1226094_controller>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
        <http://purl.org/dc/elements/1.1/contributor>
