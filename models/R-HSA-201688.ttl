<http://model.geneontology.org/ev_w_id_REACTO_R-HSA-201711_P67870_P68400_R-HSA-201717_controller_BFO_0000051_UniProtKB_P68400_REACTO_R-HSA-201711_P67870_P68400_R-HSA-201717_controller_component_Reactome_R-HSA-201717>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
