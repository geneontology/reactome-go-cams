<http://model.geneontology.org/ev_w_id_R-HSA-390593_enabled_by_UniProt_P11055_R-HSA-390593_controller_BFO_0000066_reaction_R-HSA-390593_enabled_by_UniProt_P11055_R-HSA-390593_controller_location_lociGO_0005829_Reactome_R-HSA-390522>
        a       <http://purl.obolibrary.org/obo/ECO_0000313> , <http://www.w3.org/2002/07/owl#NamedIndividual> ;
