<http://model.geneontology.org/ev_w_id_R-HSA-5591040_RO_0002333_R-HSA-5591040_UniProt_P04070_Reactome_R-HSA-5591040>
        a       <http://www.w3.org/2002/07/owl#NamedIndividual> , <http://purl.obolibrary.org/obo/ECO_0000313> ;
