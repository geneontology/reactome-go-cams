                "gamma-secretase complex" ;
        <http://purl.obolibrary.org/obo/BFO_0000051>
                <http://model.geneontology.org/UniProtKB_Q9NZ42_REACTO_R-HSA-157343_P49768_Q8WW43_Q92542_Q9NZ42_R-HSA-1251997_controller_component> , <http://model.geneontology.org/UniProtKB_Q8WW43_REACTO_R-HSA-157343_P49768_Q8WW43_Q92542_Q9NZ42_R-HSA-1251997_controller_component> , <http://model.geneontology.org/UniProtKB_Q92542_REACTO_R-HSA-157343_P49768_Q8WW43_Q92542_Q9NZ42_R-HSA-1251997_controller_component> , <http://model.geneontology.org/UniProtKB_P49768_REACTO_R-HSA-157343_P49768_Q8WW43_Q92542_Q9NZ42_R-HSA-1251997_controller_component> ;
